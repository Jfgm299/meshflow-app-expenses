{
  "schemaVersion": "1.0",
  "id": "finance",
  "name": "MeshFlow Finance",
  "version": "0.1.0",
  "type": "remote-service",
  "publisher": "meshflow",
  "compatibility": {
    "core": ">=1.0.0"
  },
  "service": {
    "baseUrl": "http://localhost:4010",
    "healthPath": "/health",
    "openapiPath": "/openapi.json"
  },
  "permissions": [],
  "settings": {
    "schema": "./settings.schema.json"
  },
  "collections": [
    {
      "name": "accounts",
      "schema": "./schemas/accounts.schema.json"
    },
    {
      "name": "categories",
      "schema": "./schemas/categories.schema.json"
    },
    {
      "name": "transactions",
      "schema": "./schemas/transactions.schema.json"
    },
    {
      "name": "recurring-transactions",
      "schema": "./schemas/recurring-transactions.schema.json"
    },
    {
      "name": "scheduled-transactions",
      "schema": "./schemas/scheduled-transactions.schema.json"
    }
  ],
  "jobs": [
    {
      "id": "process-due",
      "name": "Process due transactions",
      "path": "/internal/jobs/process-due",
      "method": "POST",
      "schedule": {
        "type": "daily",
        "time": "00:00",
        "timezone": "UTC"
      },
      "enabled": true
    }
  ],
  "automations": {
    "manifest": "./automations.manifest.json"
  }
}
